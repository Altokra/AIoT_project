/* pages/ai_chat/ai_chat.wxss */

page {
  background-color: #f0f2f5;
}

.page-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ========== 顶部标题 ========== */
.chat-header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 16px 20px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: relative;
}

.header-title {
  font-size: 18px;
  font-weight: 600;
  color: white;
}

.btn-clear {
  position: absolute;
  right: 20px;
  font-size: 13px;
  color: rgba(255, 255, 255, 0.7);
  padding: 4px 12px;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 14px;
}

/* ========== 消息列表 ========== */
.message-list {
  flex: 1;
  padding: 16px 16px;
}

.message-item {
  display: flex;
  margin-bottom: 16px;
  align-items: flex-start;
}

.message-item.user {
  flex-direction: row-reverse;
}

.avatar-icon {
  width: 36px;
  height: 36px;
  border-radius: 18px;
  background: #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
}

.user .avatar-icon {
  background: #667eea;
}

.assistant .avatar-icon {
  background: #22c55e;
}

.message-bubble {
  max-width: 70%;
  margin: 0 10px;
  padding: 12px 16px;
  border-radius: 18px;
  background: white;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.user .message-bubble {
  background: #667eea;
}

.message-text {
  font-size: 15px;
  color: #1e293b;
  line-height: 1.5;
  white-space: pre-wrap;
  word-break: break-all;
}

.user .message-text {
  color: white;
}

.message-bubble.thinking {
  background: #f8fafc;
}

.thinking-dots {
  font-size: 13px;
  color: #94a3b8;
}

/* ========== 输入区域 ========== */
.input-area {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  background: white;
  border-top: 1px solid #e5e5e5;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
}

.text-input {
  flex: 1;
  height: 40px;
  background: #f0f2f5;
  border-radius: 20px;
  padding: 0 16px;
  font-size: 15px;
  color: #1e293b;
}

.text-input:focus {
  outline: none;
}

.btn-send {
  width: 64px;
  height: 40px;
  border-radius: 20px;
  background: #667eea;
  color: white;
  font-size: 14px;
  font-weight: 500;
  margin-left: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.btn-send[disabled] {
  background: #d0d0d0;
  color: #888;
}