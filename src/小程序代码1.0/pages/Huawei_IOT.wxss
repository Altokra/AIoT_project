/* pages/Huawei_IOT.wxss */

.page-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  box-sizing: border-box;
}

/* 卡片通用样式 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  display: block;
}

/* 图书卡片 */
.book-card {
  background: #fff;
}

.book-empty {
  text-align: center;
  padding: 40rpx 0;
}

.book-empty-text {
  display: block;
  font-size: 30rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.book-empty-hint {
  display: block;
  font-size: 24rpx;
  color: #bbb;
}

.book-loading {
  text-align: center;
  padding: 40rpx 0;
}

.book-loading-text {
  font-size: 28rpx;
  color: #666;
}

.book-failed {
  text-align: center;
  padding: 20rpx 0;
  color: #ff6b6b;
  font-size: 28rpx;
}

.book-result {
  /* 查询结果展示 */
}

.book-meta {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.book-meta:last-of-type {
  border-bottom: none;
}

.book-label {
  width: 140rpx;
  font-size: 26rpx;
  color: #888;
  flex-shrink: 0;
}

.book-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  word-break: break-all;
}

.book-title-value {
  font-weight: 600;
  color: #1a1a1a;
}

.btn-query {
  width: 100%;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-send {
  width: 100%;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: #fff;
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 状态卡片 */
.status-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.status-header {
  margin-bottom: 24rpx;
}

.status-title {
  font-size: 28rpx;
  color: #fff;
  opacity: 0.9;
}

.status-hint {
  display: block;
  font-size: 26rpx;
  color: #fff;
  opacity: 0.7;
  margin-top: 8rpx;
}

.sensor-row {
  display: flex;
  justify-content: space-around;
  margin-top: 16rpx;
}

.sensor-item {
  text-align: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 24rpx 40rpx;
  min-width: 180rpx;
}

.sensor-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.sensor-label {
  display: block;
  font-size: 24rpx;
  color: #fff;
  opacity: 0.8;
}

.sensor-value {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-top: 8rpx;
}

/* 控制卡片 */
.control-card .btn-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.btn-on, .btn-off {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin: 0;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-on {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

.btn-off {
  background: linear-gradient(135deg, #536976 0%, #292e49 100%);
}

.btn-action {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  margin: 0;
  background: #f0f0f0;
  color: #666;
}

.btn-cmd {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  color: #fff;
  margin-top: 8rpx;
}

/* RGB 调节卡片 */
.rgb-card {
  padding-bottom: 16rpx;
}

.slider-row {
  margin: 28rpx 0;
}

.slider-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.slider-label {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.slider-value {
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.rgb-card slider {
  margin: 0;
}
