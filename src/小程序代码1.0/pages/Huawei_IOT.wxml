<!--pages/Huawei_IOT.wxml-->
<view class="container">

    <!-- 顶部渐变背景区域 -->
    <view class="hero-section">
        <view class="hero-bg"></view>
        <view class="hero-content">
            <view class="greeting">
                <text class="greeting-text">智能图书馆</text>
                <view class="status-badge {{isConnected ? 'online' : 'offline'}}">
                    {{isConnected ? '在线' : '离线'}}
                </view>
            </view>
            <view class="update-time">
                <text>{{lastUpdateTime || '等待连接...'}}</text>
            </view>
        </view>
    </view>

    <!-- 环境监测区域 -->
    <view class="env-section">
        <view class="env-card temp-card">
            <view class="env-ring">
                <view class="ring-center">
                    <text class="ring-value">{{temperature}}</text>
                    <text class="ring-label">温度</text>
                </view>
            </view>
            <view class="env-tip">
                <text>{{temperature > 30 ? '有点热' : '舒适'}}</text>
            </view>
        </view>

        <view class="env-card humidity-card">
            <view class="env-ring humidity-ring">
                <view class="ring-center">
                    <text class="ring-value">{{humidity}}%</text>
                    <text class="ring-label">湿度</text>
                </view>
            </view>
            <view class="env-tip">
                <text>{{humidity > 70 ? '过于潮湿' : '湿度正常'}}</text>
            </view>
        </view>

        <view class="env-card light-card">
            <view class="env-ring light-ring">
                <view class="ring-center">
                    <text class="ring-value">{{photores}}</text>
                    <text class="ring-label">光照</text>
                </view>
            </view>
            <view class="env-tip">
                <text>{{photores < 200 ? '光线充足' : photores > 600 ? '光线偏暗' : '光线一般'}}</text>
            </view>
        </view>
    </view>

    <!-- LED状态指示灯区域 -->
    <view class="led-section">
        <view class="status-leds">
            <view class="led-title">设备状态</view>
            <view class="led-list">
                <view class="led-item">
                    <view class="led-dot green {{ledStatus.green}}"></view>
                    <text class="led-text">系统待机</text>
                </view>
                <view class="led-item">
                    <view class="led-dot blue {{ledStatus.blue}}"></view>
                    <text class="led-text">图书归还</text>
                </view>
                <view class="led-item">
                    <view class="led-dot red {{ledStatus.red}}"></view>
                    <text class="led-text">图书借出</text>
                </view>
                <view class="led-item">
                    <view class="led-dot network {{ledStatus.network}}"></view>
                    <text class="led-text">网络连接</text>
                </view>
                <view class="led-item">
                    <view class="led-dot temp {{ledStatus.temp}}"></view>
                    <text class="led-text">温度告警</text>
                </view>
            </view>
        </view>
    </view>

    <!-- 藏书统计卡片 -->
    <view class="stats-section">
        <view class="stats-card">
            <view class="stats-icon-text">总</view>
            <view class="stats-info">
                <text class="stats-number">{{bookCount || 0}}</text>
                <text class="stats-label">总藏书</text>
            </view>
        </view>
        <view class="stats-card">
            <view class="stats-icon-text shelf">架</view>
            <view class="stats-info">
                <text class="stats-number">{{onShelfCount || 0}}</text>
                <text class="stats-label">在架</text>
            </view>
        </view>
        <view class="stats-card">
            <view class="stats-icon-text out">出</view>
            <view class="stats-info">
                <text class="stats-number">{{borrowedCount || 0}}</text>
                <text class="stats-label">借出</text>
            </view>
        </view>
    </view>

    <!-- 书架入口 -->
    <view class="shelf-entry">
        <view class="shelf-btn" bindtap="gotoBookshelf">
            <view class="shelf-btn-icon">📚</view>
            <view class="shelf-btn-info">
                <text class="shelf-btn-title">我的书架</text>
                <text class="shelf-btn-sub">查看所有图书详情与借还记录</text>
            </view>
            <text class="shelf-btn-arrow">›</text>
        </view>
    </view>

    <!-- 云端连接 -->
    <view class="connect-section">
        <button class="btn-connect {{isConnected ? 'connected' : ''}}" bindtap="touchBtn_subTopic" disabled="{{isConnected}}">
            {{isConnected ? '已连接' : '连接云端'}}
        </button>
    </view>

    <!-- AI 助手入口 -->
    <view class="ai-entry">
        <view class="ai-btn" bindtap="gotoAI">
            <view class="ai-btn-icon">🤖</view>
            <view class="ai-btn-info">
                <text class="ai-btn-title">AI 助手</text>
                <text class="ai-btn-sub">智能问答与系统咨询</text>
            </view>
            <text class="ai-btn-arrow">›</text>
        </view>
    </view>

    <!-- 风扇控制 -->
    <view class="fan-control">
        <view class="fan-card">
            <!-- 左侧状态 -->
            <view class="fan-left">
                <view class="fan-icon-badge {{fanActive ? 'active' : ''}}">
                    <text class="fan-icon-text">🌀</text>
                </view>
                <view class="fan-text">
                    <text class="fan-name">风扇</text>
                   
                </view>
            </view>
            <!-- 右侧按钮（上下排列）-->
            <view class="fan-right">
                <button class="fan-btn fan-btn-on {{fanActive ? 'on-active' : ''}}" bindtap="fanOn" disabled="{{isFanManualOn}}">开</button>
                <button class="fan-btn fan-btn-off {{!fanActive ? 'off-active' : ''}}" bindtap="fanOff" disabled="{{!isFanManualOn && !fanActive}}">关</button>
            </view>
        </view>
        
    </view>

    <!-- 最近动态时间线 -->
    <view class="timeline-section" wx:if="{{recentEvents.length > 0}}">
        <view class="section-header">
            <text class="section-title">最近动态</text>
            <text class="section-sub">实时更新</text>
        </view>
        <view class="timeline">
            <block wx:for="{{recentEvents}}" wx:key="index">
                <view class="timeline-item">
                    <view class="timeline-dot {{item.typeClass}}"></view>
                    <view class="timeline-content">
                        <text class="timeline-title">{{item.bookTitle || item.bookId || item.bookId}}</text>
                        <text class="timeline-time">{{item.time}}</text>
                    </view>
                    <view class="timeline-badge {{item.typeClass}}">
                        {{item.type === 'returned' ? '归还' : '借出'}}
                    </view>
                </view>
            </block>
        </view>
    </view>

    <!-- 图书信息卡片 -->
    <view class="card book-card">
        <view class="card-title-bar">
            <text class="card-title">图书信息</text>
        </view>

        <!-- 无 ISBN 时 -->
        <view wx:if="{{!bookIsbn}}" class="book-empty">
            <text class="book-empty-text">暂无图书数据</text>
            <text class="book-empty-hint">在设备端注册图书后，这里将显示信息</text>
        </view>

        <!-- 有 ISBN 但未查询 -->
        <view wx:elif="{{bookIsbn && bookQueryStatus === 'idle'}}">
            <view class="book-meta">
                <text class="book-label">ISBN</text>
                <text class="book-value">{{bookIsbn}}</text>
            </view>
            <view class="book-meta">
                <text class="book-label">状态</text>
                <text class="book-value">{{bookStatus}}</text>
            </view>
            <button class="btn-query" bindtap="touchBtn_queryBook">查询书籍信息</button>
        </view>

        <!-- 正在查询 -->
        <view wx:elif="{{bookQueryStatus === 'querying'}}" class="book-loading">
            <text class="book-loading-text">正在查询: {{bookIsbn}}</text>
        </view>

        <!-- 查询成功 -->
        <view wx:elif="{{bookQueryStatus === 'success'}}" class="book-result">
            <view class="book-meta">
                <text class="book-label">ISBN</text>
                <text class="book-value">{{bookIsbn}}</text>
            </view>
            <view class="book-meta">
                <text class="book-label">书名</text>
                <text class="book-value book-title-value">{{bookTitle}}</text>
            </view>
            <view class="book-meta">
                <text class="book-label">作者</text>
                <text class="book-value">{{bookAuthor}}</text>
            </view>
            <view class="book-meta">
                <text class="book-label">出版社</text>
                <text class="book-value">{{bookPublisher}}</text>
            </view>
            <view class="book-meta" wx:if="{{bookYear}}">
                <text class="book-label">出版年</text>
                <text class="book-value">{{bookYear}}</text>
            </view>
            <view class="book-meta">
                <text class="book-label">设备状态</text>
                <text class="book-value">{{bookStatus}}</text>
            </view>
            <button class="btn-send" bindtap="touchBtn_sendBookInfo">下发到设备</button>
        </view>

        <!-- 查询失败 -->
        <view wx:elif="{{bookQueryStatus === 'failed'}}">
            <view class="book-meta">
                <text class="book-label">ISBN</text>
                <text class="book-value">{{bookIsbn}}</text>
            </view>
            <view class="book-failed">
                <text>{{bookTitle}}</text>
                <button class="btn-query" bindtap="touchBtn_queryBook">重新查询</button>
            </view>
        </view>
    </view>

    <!-- 底部日志（可折叠） -->
    <view class="log-section" bindtap="toggleLog">
        <view class="log-header">
            <text class="log-title">调试日志</text>
            <text class="log-arrow">{{showLog ? '收起' : '展开'}}</text>
        </view>
        <view class="log-content" wx:if="{{showLog}}" catchtap="">
            <scroll-view scroll-y class="log-scroll">
                <text class="log-text">{{consoleLog}}</text>
            </scroll-view>
            <view class="log-actions" catchtap="">
                <button class="btn-clear-log" catchtap="clearLog">清空日志</button>
            </view>
        </view>
    </view>

</view>
