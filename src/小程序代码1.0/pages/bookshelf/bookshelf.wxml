<!-- pages/bookshelf/bookshelf.wxml -->
<view class="page-container">

    <!-- 顶部统计区 -->
    <view class="stats-header">
        <view class="stats-bg"></view>
        <view class="stats-content">
            <text class="stats-title">书架总览</text>
            <view class="stats-row">
                <view class="stat-item">
                    <text class="stat-num">{{totalBooks}}</text>
                    <text class="stat-label">总藏书</text>
                </view>
                <view class="stat-divider"></view>
                <view class="stat-item">
                    <text class="stat-num on-shelf-num">{{onShelfCount}}</text>
                    <text class="stat-label">在架</text>
                </view>
                <view class="stat-divider"></view>
                <view class="stat-item">
                    <text class="stat-num borrowed-num">{{borrowedCount}}</text>
                    <text class="stat-label">借出</text>
                </view>
            </view>
        </view>
    </view>

    <!-- 操作栏 -->
    <view class="action-bar">
        <text class="section-title">全部图书</text>
        <view class="btn-refresh" bindtap="onRefresh">
            <text>刷新</text>
        </view>
    </view>

    <!-- 加载中 -->
    <view class="loading-section" wx:if="{{loading}}">
        <view class="loading-spinner"></view>
        <text class="loading-text">加载中...</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-section" wx:if="{{!loading && bookList.length === 0}}">
        <text class="empty-icon">📚</text>
        <text class="empty-text">书架是空的</text>
        <text class="empty-hint">在设备端注册图书后将自动出现在这里</text>
    </view>

    <!-- 图书列表 -->
    <view class="book-list" wx:if="{{!loading && bookList.length > 0}}">
        <view class="book-card" wx:for="{{bookList}}" wx:key="isbn" bindtap="onBookTap" data-index="{{index}}">
            <view class="book-header">
                <view class="book-info">
                    <text class="book-title">{{item.displayTitle}}</text>
                    <text class="book-meta" wx:if="{{item.displayAuthor}}">{{item.displayAuthor}}</text>
                </view>
                <view class="book-status {{item.statusClass}}">
                    {{item.statusText}}
                </view>
            </view>
            <view class="book-stats">
                <view class="book-stat">
                    <text class="book-stat-value">{{item.borrowCountText}}</text>
                </view>
                <view class="book-stat-divider"></view>
                <view class="book-stat">
                    <text class="book-stat-value">{{item.readingDisplay}}</text>
                    <text class="book-stat-label">阅读时长</text>
                </view>
                <view class="book-stat-divider"></view>
                <view class="book-stat">
                    <text class="book-stat-value">{{item.lastEventType}}</text>
                    <text class="book-stat-label">{{item.lastEventTime}}</text>
                </view>
            </view>
        </view>
    </view>

    <!-- 详情弹出层 -->
    <view class="detail-overlay" wx:if="{{showDetail}}" bindtap="closeDetail">
        <view class="detail-panel" catchtap="">
            <view class="detail-header">
                <text class="detail-title">{{detailBook.displayTitle}}</text>
                <view class="detail-close" bindtap="closeDetail">
                    <text>关闭</text>
                </view>
            </view>

            <view class="detail-info">
                <view class="detail-row">
                    <text class="detail-label">作者</text>
                    <text class="detail-value">{{detailBook.author || '未知'}}</text>
                </view>
                <view class="detail-row">
                    <text class="detail-label">ISBN</text>
                    <text class="detail-value">{{detailBook.isbn}}</text>
                </view>
                <view class="detail-row">
                    <text class="detail-label">状态</text>
                    <text class="detail-value status-text {{detailBook.statusClass}}">{{detailBook.statusText}}</text>
                </view>
                <view class="detail-row">
                    <text class="detail-label">累计借出</text>
                    <text class="detail-value">{{detailBook.borrowCount || 0}} 次</text>
                </view>
                <view class="detail-row">
                    <text class="detail-label">累计阅读</text>
                    <text class="detail-value">{{detailBook.readingDisplay}}</text>
                </view>
            </view>

            <!-- 借还历史 -->
            <view class="detail-section" wx:if="{{detailBook.history.length > 0}}">
                <text class="detail-section-title">借还记录</text>
                <view class="history-list">
                    <view class="history-item" wx:for="{{detailBook.history}}" wx:for-item="evt" wx:for-index="idx" wx:key="idx">
                        <view class="history-dot {{evt.type === 'returned' ? 'dot-green' : 'dot-orange'}}"></view>
                        <view class="history-info">
                            <text class="history-type">{{evt.typeText}}</text>
                            <text class="history-time">{{evt.timeDisplay}}</text>
                            <text class="history-duration" wx:if="{{evt.durationDisplay}}">{{evt.durationDisplay}}</text>
                        </view>
                    </view>
                </view>
            </view>
        </view>
    </view>

</view>
